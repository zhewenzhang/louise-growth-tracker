# 依賴
node_modules/

# 構建輸出
dist/

# 環境變數（重要！）
.env
.env.local
.env.*.local

# 編輯器
.vscode/
.idea/
*.swp
*.swo

# 操作系統
.DS_Store
Thumbs.db

# 日誌
*.log
npm-debug.log*

# 備份文件
*-backup-old/

# 備份 JSON 含個人資料，不 commit 進 repo（存到 Firebase Storage）
# 只保留 summary.json 和 index.json（純統計，無個人資料）
backups/*.json
!backups/summary.json
!backups/index.json

# gstack 相關（可選）
.gstack/

# Supabase 配置（已在 .env 中保護）
# supabase-init.sql 可以保留作為參考
